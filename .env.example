# ==============================
# Database
# ==============================
DATABASE_URL="postgresql://postgres:password@localhost:5432/japan_buy_helper"

# ==============================
# Admin Auth (JWT Secret)
# ==============================
# 請設定一組隨機長字串
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Admin 預設帳號密碼 (seed 時使用)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin1234"

# ==============================
# Next.js
# ==============================
NEXTAUTH_URL="http://localhost:3000"

# ==============================
# 圖片上傳 (選擇其中一種)
# ==============================

# 方案 A: 本地 public/uploads (預設, 無需設定)
UPLOAD_PROVIDER="local"

# 方案 B: Cloudinary
# UPLOAD_PROVIDER="cloudinary"
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# 方案 C: Supabase Storage
# UPLOAD_PROVIDER="supabase"
# SUPABASE_URL=""
# SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""
# SUPABASE_STORAGE_BUCKET="product-images"

# ==============================
# Google Sheets 同步 (可選)
# ==============================
# 若不設定，系統使用 mock 模式，主流程不受影響

# GOOGLE_SHEETS_ENABLED="true"
# GOOGLE_SHEETS_ID="your-google-sheet-id"

# 方案 A: Service Account JSON (推薦)
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# 方案 B: OAuth2
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_REFRESH_TOKEN=""
